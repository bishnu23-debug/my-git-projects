          <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="JSR223 PreProcessor">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import java.util.UUID

// Generate unique values
def uniqueId = UUID.randomUUID().toString().replace(&quot;-&quot;, &quot;&quot;).substring(0,8)

def email = &quot;emailll.${uniqueId}@yopmail.com&quot;

// Set variables in JMeter
vars.put(&quot;email&quot;, email)
vars.put(&quot;password&quot;, &quot;Test@123&quot;)
</stringProp>
          </JSR223PreProcessor>
          <hashTree/>
          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">def filePath = &quot;C:/Users/ASUS/Downloads/apache-jmeter-5.6.3/apache-jmeter-5.6.3/bin/registered_users.csv&quot;

def email = vars.get(&quot;email&quot;)
def password = vars.get(&quot;password&quot;)

def file = new File(filePath)

// Thread-safe write
synchronized(org.apache.jmeter.util.JMeterUtils.class) {
    file.append(email + &quot;,&quot; + password + System.lineSeparator())
}</stringProp>
          </JSR223PostProcessor>
